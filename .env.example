# Control Server Docker 环境变量配置
# 复制此文件为 .env 并修改相应的值

# ========== 数据库配置 ==========
DB_PASSWORD=your_secure_mysql_password

# ========== Redis 配置 ==========
# 留空表示不设置密码
REDIS_PASSWORD=

# ========== 商户API配置 ==========
MERCHANT_API_PASSWORD=MerchantAPI@2026

# ========== SSH 默认配置（可选） ==========
# SSH_USERNAME=root
# SSH_PASSWORD=your_default_ssh_password
# SSH_PORT=22

# ========== 阿里云默认配置（可选） ==========
# ALIYUN_PASSWORD=your_aliyun_instance_password

# ========== GOST 配置（可选） ==========
# GOST_DIRECT_PORT=10543
